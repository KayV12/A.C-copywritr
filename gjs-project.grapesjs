","classes":["section-intro"],"components":[{"tagName":"span","type":"text","name":"Section Eyebrow","classes":["section-eyebrow"],"components":[{"type":"textnode","content":"About"}]},{"tagName":"h2","type":"heading","name":"About Heading","classes":["gjs-t-h2","about-heading"],"components":[{"type":"textnode","content":"Meet Alex Carter"}]},{"tagName":"p","type":"text","name":"About Paragraph","classes":["about-paragraph"],"components":[{"type":"textnode","content":"I help SaaS brands and digital businesses clarify their message, sharpen their positioning, and turn more traffic into leads and sales. Over the last five years, I’ve written conversion-focused copy for founders, agencies, ecommerce brands, and coaches who needed messaging that actually moved numbers."}]},{"tagName":"p","type":"text","name":"About Paragraph","classes":["about-paragraph"],"components":[{"type":"textnode","content":"My approach blends customer research, strategic positioning, and persuasive writing so your website and campaigns speak directly to what buyers care about most."}]}]},{"name":"About Highlights","classes":["about-highlights"],"components":[{"name":"Highlight Card","classes":["hover-lift","highlight-card"],"components":[{"tagName":"span","type":"text","name":"Highlight Icon","classes":["highlight-icon"],"components":[{"type":"textnode","content":"01"}]},{"name":"Highlight Text Group","classes":["highlight-text-group"],"components":[{"tagName":"h3","type":"heading","name":"Highlight Title","classes":["highlight-title"],"components":[{"type":"textnode","content":"5+ years of hands-on copy experience"}]},{"tagName":"p","type":"text","name":"Highlight Text","classes":["highlight-text"],"components":[{"type":"textnode","content":"Focused on conversion messaging for growth-stage businesses and online offers."}]}]}]},{"name":"Highlight Card","classes":["hover-lift","highlight-card"],"components":[{"tagName":"span","type":"text","name":"Highlight Icon","classes":["highlight-icon"],"com